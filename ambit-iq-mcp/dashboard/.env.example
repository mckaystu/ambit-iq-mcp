# Copy to .env.local for local Vercel dev / serverless API routes (never commit secrets).

# Neon (required for rules + shadow impact that reads agent_gate_decision_logs)
DATABASE_URL=

# OpenAI — used only by /api/policy-manager (server-side). Not exposed to the browser.
# Required for Policy IDE "Generate policy" (Chat Completions + JSON mode). Returns 503 if unset.
OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Local Policy IDE: run API + UI together (recommended)
#   npx vercel dev --listen 3000
# Or two terminals: npm run dev:api  (port 3000)  +  npm run dev  (Vite proxies /api → 3000)
#
# Do NOT set VITE_DASHBOARD_API_BASE to a random localhost port (e.g. another Next app).
# Leave unset so /api uses same origin (vercel dev) or Vite's proxy.
# VITE_DASHBOARD_API_BASE=
#
# Optional: proxy /api to another deployment during Vite-only dev
# VITE_DEV_API_PROXY_TARGET=https://your-dashboard.vercel.app

# Top rejected PR test script (search + analyze)
GITHUB_TOKEN=
# Optional single repo override (owner/repo). Leave blank to use REPO_SEARCH_QUERY via GitHub GraphQL search.
GITHUB_REPO=
TEST_TENANT_ID=
TEST_TENANT_IDS=
POLICY_MANAGER_URL=http://localhost:3000/api/policy-manager
TOP_REJECTION_LIMIT=5
# Exact query requested for active public React/Vite PR rejections.
REPO_SEARCH_QUERY=is:pr is:closed is:unmerged stars:>1000 "vite" in:path "react" in:path comments:>15
GITHUB_REQUEST_DELAY_MS=0
#
# Optional: if your Vercel project protects /api/policy-manager with bearer auth,
# set POLICY_MANAGER_AUTH_TOKEN (falls back to MCP_AUTH_TOKEN).
POLICY_MANAGER_AUTH_TOKEN=
