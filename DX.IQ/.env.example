# Copy to ".env.local" in this folder. Required for local API routes under /api.
# Start local API with `npm run dev:api` and UI with `npm run dev`.
#
# Neon: Dashboard → your project → Connect → copy the pooled connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Other env names like POSTGRES_URL / POSTGRES_PRISMA_URL are accepted too.

# Optional Phase-1 graph sidecar (webhook endpoint for node/edge upserts from scan ingestion).
# Example: GRAPH_SIDECAR_URL=https://your-graph-ingest.example.com/events
# GRAPH_SIDECAR_URL=

# FalkorDB Cloud → Connect / Redis URL (TLS is usually rediss://default:PASSWORD@HOST:PORT).
# Used by POST /api/graph/events, graph health, and WCM hierarchy sync MERGEs.
FALKOR_REDIS_URL=
FALKOR_GRAPH_NAME=dxiq

# Optional: scan emits events here; local dev often points at this same API:
# GRAPH_SIDECAR_URL=http://localhost:8787/api/graph/events

# Optional: protect /api/graph/events and sidecar calls.
# GRAPH_SIDECAR_TOKEN=replace-with-long-random-token
