# PostgreSQL (e.g. Neon) — never commit real credentials. Use the pooled URL on Vercel/serverless.
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-POOLER-HOST.neon.tech/neondb?sslmode=require"

# Optional: OPA REST API (e.g. http://localhost:8181). If unset, agent.gate uses the built-in policy engine as a bridge.
OPA_URL=

# OPA document path for decision (default bundles input under { code, intent_prompt, profile_id })
OPA_POLICY_PATH=data.agent.gate.decision

# MCP HTTP auth (Vercel / production)
MCP_AUTH_TOKEN=

# Tamper-evident chain (required when DATABASE_URL is set, for log_vibe_transaction → Postgres)
# PEM with literal \n for newlines, e.g. -----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----
AMBIT_SIGNING_KEY=

# Optional: RSA public PEM for verify_audit_integrity signature checks (skipped if unset)
AMBIT_VERIFYING_KEY=

# Pinecone — query_governance_standards (index must match ingest dimension, typically 384)
PINECONE_API_KEY=
# Optional; default agent-gate-standards
PINECONE_INDEX_NAME=

# Hugging Face Inference API — embeddings for governance search (avoids bundling Transformers.js on Vercel)
# https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=
# Optional; default sentence-transformers/all-MiniLM-L6-v2 (aligns with Xenova/all-MiniLM-L6-v2 ingest)
HF_EMBEDDING_MODEL_ID=

# Optional: Vercel Blob uploads for session artifacts (HTML certificate, traceability, BoI/report markdown)
# When set, URLs are written to ambit_decision_logs.metadata.artifact_refs
BLOB_READ_WRITE_TOKEN=
