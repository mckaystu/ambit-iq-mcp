{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ambitiq.local/schemas/rule.schema.json",
  "title": "Ambit.IQ Rule",
  "type": "object",
  "required": ["id", "domain", "title", "severity", "rationale", "remediation"],
  "properties": {
    "id": { "type": "string", "pattern": "^[A-Z]+-[0-9]{3}$" },
    "domain": { "type": "string", "enum": ["quality", "ux", "regulatory", "security"] },
    "title": { "type": "string" },
    "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "appliesTo": { "type": "array", "items": { "type": "string" }, "default": ["all"] },
    "rationale": { "type": "string" },
    "remediation": { "type": "string" },
    "pattern": { "type": "string", "description": "Regex source string for deterministic scans" },
    "test": { "type": "string", "description": "Optional custom evaluator id/function name" }
  },
  "additionalProperties": false
}
