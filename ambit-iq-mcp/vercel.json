{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "public",
  "functions": {
    "api/mcp.js": {
      "maxDuration": 300,
      "includeFiles": "lib/**"
    }
  },
  "rewrites": [{ "source": "/mcp", "destination": "/api/mcp" }]
}
